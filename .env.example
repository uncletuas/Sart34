NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

DATABASE_URL=postgresql://sart34:sart34@localhost:5432/sart34?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
DISABLE_QUEUES=false

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

ENCRYPTION_KEY=change-me-32-byte-key-change-me!!
UPLOAD_ROOT=uploads
PUBLIC_BASE_URL=http://localhost:4000
# Frontend origin — OAuth callbacks redirect the browser back here
APP_BASE_URL=http://localhost:5173

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/v1/integrations/meta/callback

# Google Ads OAuth (Google Cloud Console + Google Ads developer token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google/callback

# TikTok Ads (TikTok for Business -> Marketing API app)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/v1/integrations/tiktok/callback

# WhatsApp Business Cloud API (uses Meta App or its own)
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_REDIRECT_URI=http://localhost:4000/api/v1/integrations/whatsapp/callback
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

SART34_ADMIN_EMAIL=admin@sart34.test
SART34_ADMIN_PASSWORD=AdminPassword123!
