generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENCY_ADMIN
  SUPER_ADMIN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MARKETING_MANAGER
  SALES_STAFF
  VIEWER
}

enum WorkspaceType {
  BUSINESS
  AGENCY
  CLIENT
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  READY_TO_LAUNCH
  SUBMITTED
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  REJECTED
  ARCHIVED
}

enum CampaignGoal {
  WHATSAPP_MESSAGES
  GENERATE_LEADS
  GET_CALLS
  WEBSITE_TRAFFIC
  SELL_PRODUCTS
  REAL_ESTATE_LISTING
  EVENT_REGISTRATION
  BOOK_APPOINTMENTS
  BRAND_AWARENESS
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  META
  WHATSAPP
  TIKTOK
  GOOGLE
  LINKEDIN
  X
}

enum CreativeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IntegrationProvider {
  META
  WHATSAPP
  PAYSTACK
  FLUTTERWAVE
  GOOGLE
  TIKTOK
  LINKEDIN
  X
}

enum IntegrationStatus {
  CONNECTED
  EXPIRED
  REVOKED
  FAILED
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  INTERESTED
  FOLLOW_UP
  APPOINTMENT_SCHEDULED
  NEGOTIATION
  WON
  LOST
}

enum LeadTemperature {
  HOT
  WARM
  COLD
  UNKNOWN
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
  CALL
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum CreditTransactionType {
  PURCHASE
  DEDUCTION
  REFUND
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PolicyRiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

enum HumanReviewStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum SocialPostStatus {
  DRAFT
  PUBLISHING
  PUBLISHED
  PARTIAL
  FAILED
}

model User {
  id                   String                @id @default(cuid())
  firstName            String
  lastName             String
  email                String                @unique
  passwordHash         String?
  role                 UserRole              @default(USER)
  googleId             String?               @unique
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  memberships          WorkspaceMember[]
  invitationsSent      WorkspaceInvitation[] @relation("InvitationsSent")
  campaignsCreated     Campaign[]            @relation("CampaignCreator")
  leadNotes            LeadNote[]
  assignedLeads        Lead[]                @relation("AssignedLeads")
  reviewedPolicies     PolicyReview[]        @relation("PolicyReviewer")
  auditLogs            AuditLog[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id                    String                 @id @default(cuid())
  ownerId               String
  type                  WorkspaceType          @default(BUSINESS)
  name                  String
  industry              String?
  logoUrl               String?
  description           String?
  location              String?
  website               String?
  whatsappNumber        String?
  email                 String?
  phone                 String?
  socialHandles         Json?
  defaultCurrency       String                 @default("NGN")
  businessGoals         Json?
  targetCustomerProfile String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  members               WorkspaceMember[]
  invitations           WorkspaceInvitation[]
  agencyClients         AgencyClient[]         @relation("Agency")
  agencyParent          AgencyClient?          @relation("Client")
  wallet                CreditWallet?
  campaigns             Campaign[]
  creatives             AdCreative[]
  integrations          IntegrationAccount[]
  leads                 Lead[]
  payments              PaymentTransaction[]
  auditLogs             AuditLog[]
  socialPosts           SocialPost[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  token       String        @unique
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User          @relation("InvitationsSent", fields: [invitedById], references: [id])
}

model AgencyClient {
  id          String    @id @default(cuid())
  agencyId    String
  clientId    String    @unique
  createdAt   DateTime  @default(now())
  agency      Workspace @relation("Agency", fields: [agencyId], references: [id], onDelete: Cascade)
  client      Workspace @relation("Client", fields: [clientId], references: [id], onDelete: Cascade)
}

model Campaign {
  id                 String              @id @default(cuid())
  workspaceId        String
  name               String
  goal               CampaignGoal
  platform           Platform            @default(META)
  objective          String?
  status             CampaignStatus      @default(DRAFT)
  budget             Decimal?
  durationDays       Int?
  startDate          DateTime?
  endDate            DateTime?
  productDetails     Json?
  aiStrategyJson     Json?
  creditCost         Int                 @default(0)
  externalCampaignId String?
  createdById        String
  approvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("CampaignCreator", fields: [createdById], references: [id])
  copies             AdCopy[]
  creatives          AdCreative[]
  leadQuestions      LeadFormQuestion[]
  approvals          CampaignApproval[]
  metrics            CampaignMetric[]
  launchJobs         CampaignLaunchJob[]
  aiGenerations      AiGeneration[]
  policyReviews      PolicyReview[]
  leads              Lead[]
}

model CampaignApproval {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  approved   Boolean
  notes      String?
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AdCreative {
  id          String         @id @default(cuid())
  workspaceId String
  campaignId  String?
  fileUrl     String
  fileName    String
  fileType    String
  fileSize    Int
  dimensions  String?
  durationSec Int?
  status      CreativeStatus @default(PENDING)
  uploadedBy  String
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model AdCopy {
  id          String   @id @default(cuid())
  campaignId  String
  primaryText String
  headline    String
  description String?
  callToAction String?
  platform    Platform
  aiGenerated Boolean  @default(true)
  createdAt   DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model LeadFormQuestion {
  id         String   @id @default(cuid())
  campaignId String
  question   String
  required   Boolean  @default(false)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignLaunchJob {
  id         String    @id @default(cuid())
  campaignId String
  provider   IntegrationProvider @default(META)
  status     JobStatus  @default(QUEUED)
  payload    Json?
  result     Json?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AiGeneration {
  id          String   @id @default(cuid())
  workspaceId String
  campaignId  String?
  type        String
  prompt      String
  outputJson  Json
  provider    String
  model       String
  creditCost  Int      @default(0)
  createdAt   DateTime @default(now())
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model AiTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  industry  String?
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PolicyReview {
  id              String            @id @default(cuid())
  campaignId      String
  riskLevel       PolicyRiskLevel
  flaggedReasons  Json
  aiReviewJson    Json?
  humanStatus     HumanReviewStatus @default(NOT_REQUIRED)
  reviewedById    String?
  createdAt       DateTime          @default(now())
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewedBy      User?             @relation("PolicyReviewer", fields: [reviewedById], references: [id])
}

model FlaggedContent {
  id          String          @id @default(cuid())
  workspaceId String?
  campaignId  String?
  riskLevel   PolicyRiskLevel
  reason      String
  status      HumanReviewStatus @default(PENDING)
  createdAt   DateTime        @default(now())
}

model IntegrationAccount {
  id                    String              @id @default(cuid())
  workspaceId           String
  provider              IntegrationProvider
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  externalAccountId     String?
  accountName           String?
  metadata              Json?
  status                IntegrationStatus   @default(CONNECTED)
  expiresAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  workspace             Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Lead {
  id              String          @id @default(cuid())
  workspaceId     String
  campaignId      String?
  fullName        String
  phone           String?
  email           String?
  whatsappNumber  String?
  sourcePlatform  Platform?
  interest        String?
  budget          Decimal?
  location        String?
  status          LeadStatus      @default(NEW_LEAD)
  temperature     LeadTemperature @default(UNKNOWN)
  assignedToId    String?
  nextFollowUpAt  DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign        Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignedTo      User?           @relation("AssignedLeads", fields: [assignedToId], references: [id])
  notes           LeadNote[]
  messages        FollowUpMessage[]
  reminders       FollowUpReminder[]
  conversations   ConversationEntry[]
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  note      String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model FollowUpMessage {
  id          String        @id @default(cuid())
  leadId      String
  channel     MessageChannel
  message     String
  status      MessageStatus @default(DRAFT)
  aiGenerated Boolean       @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime      @default(now())
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUpReminder {
  id        String   @id @default(cuid())
  leadId    String
  dueAt     DateTime
  note      String?
  doneAt    DateTime?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model ConversationEntry {
  id        String         @id @default(cuid())
  leadId    String
  channel   MessageChannel
  direction String
  body      String
  createdAt DateTime       @default(now())
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model PipelineStage {
  id        String     @id @default(cuid())
  key       LeadStatus @unique
  name      String
  position  Int
  active    Boolean    @default(true)
}

model CreditWallet {
  id          String              @id @default(cuid())
  workspaceId String              @unique
  balance     Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]
}

model CreditTransaction {
  id        String                @id @default(cuid())
  walletId  String
  type      CreditTransactionType
  amount    Int
  reason    String
  reference String?
  status    TransactionStatus     @default(SUCCESS)
  createdAt DateTime              @default(now())
  wallet    CreditWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id                String            @id @default(cuid())
  workspaceId       String
  provider          IntegrationProvider @default(PAYSTACK)
  amount            Decimal
  currency          String            @default("NGN")
  creditsPurchased  Int
  providerReference String            @unique
  authorizationUrl  String?
  status            TransactionStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CreditBundle {
  id        String   @id @default(cuid())
  name      String
  credits   Int
  amount    Decimal
  currency  String   @default("NGN")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  event       String
  reference   String?
  payload     Json
  processedAt DateTime?
  createdAt   DateTime @default(now())
}

model CampaignMetric {
  id             String   @id @default(cuid())
  campaignId     String
  date           DateTime
  impressions    Int      @default(0)
  reach          Int      @default(0)
  clicks         Int      @default(0)
  leads          Int      @default(0)
  spend          Decimal  @default(0)
  costPerLead    Decimal  @default(0)
  conversions    Int      @default(0)
  rawMetricsJson Json?
  createdAt      DateTime @default(now())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  workspaceId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model ApiLog {
  id        String   @id @default(cuid())
  method    String
  path      String
  status    Int
  latencyMs Int
  userId    String?
  createdAt DateTime @default(now())
}

model IntegrationError {
  id          String              @id @default(cuid())
  workspaceId String?
  provider    IntegrationProvider
  message     String
  context     Json?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialPost {
  id          String           @id @default(cuid())
  workspaceId String
  caption     String
  mediaUrl    String?
  mediaType   String?
  platforms   String[]
  status      SocialPostStatus @default(DRAFT)
  results     Json?
  createdById String
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}
